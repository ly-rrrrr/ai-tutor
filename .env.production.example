APP_DOMAIN=app.example.com
APP_ORIGIN=https://app.example.com
PORT=3000
NODE_ENV=production
MYSQL_DATA_DIR=/mnt/data/ai-tutor/mysql
CADDY_DATA_DIR=/mnt/data/ai-tutor/caddy/data
CADDY_CONFIG_DIR=/mnt/data/ai-tutor/caddy/config
CADDY_HTTP_BIND=127.0.0.1:80
LOCAL_STORAGE_HOST_DIR=/mnt/data/ai-tutor/storage

MYSQL_PASSWORD=replace-with-mysql-password
MYSQL_ROOT_PASSWORD=replace-with-root-password
DATABASE_URL=mysql://ai_tutor:replace-with-mysql-password@mysql:3306/ai_tutor

BETTER_AUTH_SECRET=replace-with-a-long-random-secret
ADMIN_EMAIL=owner@example.com

AI_BASE_URL=https://aihubmix.com/v1
AI_API_KEY=replace-me
AI_CHAT_MODEL=gemini-2.5-flash-lite
AI_STT_MODEL=whisper-1
AI_TTS_MODEL=gpt-4o-mini-tts

# Storage driver: local | s3
STORAGE_DRIVER=local

# Optional S3/COS storage. Required only when STORAGE_DRIVER=s3.
S3_ENDPOINT=https://cos.ap-hongkong.myqcloud.com
S3_REGION=ap-hongkong
S3_BUCKET=ai-tutor-audio-1250000000
S3_ACCESS_KEY_ID=replace-me
S3_SECRET_ACCESS_KEY=replace-me
S3_PUBLIC_BASE_URL=

# Email provider: disabled | smtp | tencent_ses_api
EMAIL_PROVIDER=tencent_ses_api
GUEST_ACCESS_ENABLED=false
EMAIL_FROM=AI Tutor <noreply@example.com>
EMAIL_REPLY_TO=

CLOUDFLARE_TURNSTILE_SITE_KEY=replace-me
CLOUDFLARE_TURNSTILE_SECRET_KEY=replace-me

# SMTP option
SMTP_HOST=smtp.qcloudmail.com
SMTP_PORT=587
SMTP_USER=replace-me
SMTP_PASS=replace-me
SMTP_FROM_EMAIL=AI Tutor <noreply@example.com>

# Tencent SES API option
TENCENT_SES_SECRET_ID=replace-me
TENCENT_SES_SECRET_KEY=replace-me
TENCENT_SES_REGION=ap-guangzhou
TENCENT_SES_ALLOW_SIMPLE_CONTENT=false
TENCENT_SES_VERIFICATION_OTP_TEMPLATE_ID=replace-me
TENCENT_SES_ADMIN_NOTIFICATION_TEMPLATE_ID=replace-me

# Cloudflare Tunnel
CLOUDFLARE_TUNNEL_TOKEN=replace-with-cloudflare-tunnel-token
